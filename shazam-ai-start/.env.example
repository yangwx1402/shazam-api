# =======================================================
# Shazam AI Agent 环境变量配置模板
# =======================================================
# 使用说明:
# 1. 复制此文件为 .env
# 2. 填入你的真实 API Key
# 3. .env 文件不会被 Git 跟踪，可以安全存储敏感信息
#
# 命令:
#   cp .env.example .env
#   # 然后编辑 .env 文件
# =======================================================

# ----------------- OpenAI 配置 -----------------
# 【必填】API Key
OPENAI_API_KEY=sk-your-api-key-here

# 【可选】API 基础 URL
# 百炼(DashScope): https://dashscope.aliyuncs.com
# OpenAI 官方: https://api.openai.com
OPENAI_BASE_URL=https://dashscope.aliyuncs.com

# 【可选】模型名称
# 百炼: qwen-turbo, qwen-plus, qwen-max
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo
OPENAI_MODEL=qwen-plus

# 【可选】温度参数 (0.0 - 2.0)
OPENAI_TEMPERATURE=0.7

# ----------------- Agent 配置 -----------------
AGENT_PROVIDER=openai
AGENT_MODEL=qwen-plus
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=2048

# ----------------- 服务器配置 -----------------
SERVER_PORT=8080

# ----------------- 日志配置 -----------------
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_AGENT=DEBUG
LOG_LEVEL_AI=INFO
