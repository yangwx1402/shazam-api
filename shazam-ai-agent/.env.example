# =======================================================
# Shazam AI Agent 环境变量配置模板
# =======================================================
# 使用说明:
# 1. 复制此文件为 .env
# 2. 填入你的真实 API Key
# 3. .env 文件不会被 Git 跟踪，可以安全存储敏感信息
#
# 命令:
#   cp .env.example .env
#   # 然后编辑 .env 文件
# =======================================================

# ----------------- OpenAI 配置 -----------------
# 【必填】OpenAI API Key
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# 【可选】OpenAI API 基础 URL
# 默认：https://api.openai.com/v1
# 如果使用代理或其他兼容 API，可修改此项
# OPENAI_BASE_URL=https://api.openai.com/v1

# 【可选】模型名称
# 可选值：gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo 等
OPENAI_MODEL=gpt-4o-mini

# 【可选】温度参数 (0.0 - 2.0)
# 越高越随机，越低越确定
OPENAI_TEMPERATURE=0.7

# ----------------- Agent 配置 -----------------
# 【可选】AI 提供商类型
# 可选值：openai, ollama, azure
AGENT_PROVIDER=openai

# 【可选】Agent 使用的模型
AGENT_MODEL=gpt-4o-mini

# 【可选】Agent 温度参数
AGENT_TEMPERATURE=0.7

# 【可选】最大 token 数
AGENT_MAX_TOKENS=2048

# ----------------- 服务器配置 -----------------
# 【可选】服务端口
SERVER_PORT=8080

# ----------------- 日志配置 -----------------
# 【可选】根日志级别
LOG_LEVEL_ROOT=INFO

# 【可选】Agent 日志级别
LOG_LEVEL_AGENT=DEBUG

# 【可选】Spring AI 日志级别
LOG_LEVEL_AI=INFO
